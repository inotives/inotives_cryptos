# ===========================================================================================
# INOTIVES_CRYPTOS - Environment Settings
# ===========================================================================================

# ---- APP SETTINGS -----
ENV_NAME=local
DEBUG=true
PROJECT_NAME=inotives_data

# ---- POSTGRES CONNECTION ----
# Note: DB_PORT 5435 is used for host access, but internally n8n uses 5432
DB_CONTAINER_NAME=inotives_db
DB_HOST=localhost
DB_PORT=5435
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=inotives_db

# ---- FASTAPI SETTINGS ----
API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=yoursecretkeyhere

# ---- DBT SETTINGS ----
DBT_PROFILES_DIR=./analytics
DBT_TARGET=dev
DBT_SCHEMA=analytics

# ---- CRYPTO API KEYS ----
COINMARKETCAP_API_KEY=your_key
COINGECKO_API_KEY=your_key
# Set to "pro" if using a paid CoinGecko Pro key, otherwise leave as "demo" (free tier)
COINGECKO_API_KEY_TYPE=demo

# ---- EXCHANGE API KEYS (for bots) ----
CRYPTOCOM_API_KEY=your_key
CRYPTOCOM_API_SECRET=your_secret
BINANCE_API_KEY=your_key
BINANCE_API_SECRET=your_secret

# ---- PREFECT SETTINGS ----
PREFECT_API_URL=http://localhost:4200/api

# ---- GRAFANA SETTINGS ----
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ---- DBMATE Metadata -----
DBMATE_MIGRATIONS_DIR=./db/migrations
DBMATE_SCHEMA_FILE=./db/schema.sql