# ===========================================================================================
# INOTIVES TRADINGS - Environment Settings
# ===========================================================================================
# Copy this file to .env.local and fill in your values:
#   cp configs/envs/.env.example configs/envs/.env.local

# ---- APP SETTINGS -----
ENV_NAME=local
DEBUG=true

# ---- POSTGRES CONNECTION ----
# This project connects to the shared inotives_aibots database (managed by the aibots project).
# The DB runs on port 5445 via the aibots project's Docker Compose.
DB_HOST=localhost
DB_PORT=5445
DB_USER=inotives
DB_PASSWORD=your_password
DB_NAME=inotives_aibots

# ---- CRYPTO DATA API KEYS ----
# CoinGecko (optional — free/demo tier works without a key)
COINGECKO_API_KEY=your_key
# Set to "pro" if using a paid CoinGecko Pro key, otherwise leave as "demo"
COINGECKO_API_KEY_TYPE=demo

# CoinMarketCap (optional — only needed for CMC CSV seeding)
COINMARKETCAP_API_KEY=your_key

# ---- EXCHANGE API KEYS (for bots) ----
# Crypto.com (optional — public endpoints work without keys, needed for live trading)
CRYPTOCOM_API_KEY=your_key
CRYPTOCOM_API_SECRET=your_secret

# Binance (optional)
BINANCE_API_KEY=your_key
BINANCE_API_SECRET=your_secret

# ---- DBMATE Metadata -----
DBMATE_MIGRATIONS_DIR=./db/migrations
DBMATE_SCHEMA_FILE=./db/schema.sql
